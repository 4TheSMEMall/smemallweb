generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUSINESS_OWNER
  ADMIN
  PARTNER
  CONSULTANT
  PROVIDER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String      @map("password_hash")
  firstName    String      @map("first_name")
  lastName     String      @map("last_name")
  role         UserRole
  status       UserStatus  @default(ACTIVE)
  phone        String?
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  bhcResults      BhcResult[]
  bhcGaps         BhcGap[]
  provider        Provider?
  serviceRequests ServiceRequest[]
  wibgScores      WibgScore[]

  @@map("users")
}

// Stores every BHC assessment a user completes.
// assessment_id is BHC's own UUID — we use it to proxy PDF requests
// back to BHC's report endpoint on demand (no stored PDF URL needed).
model BhcResult {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  assessmentId  String   @unique @map("assessment_id") // BHC's UUID
  score         Int
  maxScore      Int      @map("max_score")
  percentage    Int      // 0–100
  status        String   // "Critical" | "Fair" | "Good" | "Excellent"
  sectionScores Json     @map("section_scores") // JSONB — array of { name, score, max_score, percentage }
  gaps          Json?    @map("gaps") // JSONB — array of { gap_title, section, description, priority, needs_provider, service_tag }, nullable for rows saved before this field existed
  completedAt   DateTime @map("completed_at")
  createdAt     DateTime @default(now()) @map("created_at")

  user          User     @relation(fields: [userId], references: [id])
  bhcGaps       BhcGap[]

  @@index([userId])
  @@map("bhc_results")
}

enum GapStatus {
  OPEN
  REQUESTED
  IN_PROGRESS
  CLOSED
}

// Individual, trackable gaps promoted from BhcResult.gaps (the raw snapshot).
// Each row has a real id so it can be requested as a service and tracked
// through a job lifecycle — the raw JSON snapshot on BhcResult cannot.
model BhcGap {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  bhcResultId   String    @map("bhc_result_id") // the assessment that produced this gap
  section       String
  gapTitle      String    @map("gap_title")
  description   String
  priority      String    // "CRITICAL" | "HIGH" | "MEDIUM" | "LOW"
  needsProvider Boolean   @map("needs_provider")
  serviceTag    String?   @map("service_tag")
  status        GapStatus @default(OPEN)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User      @relation(fields: [userId], references: [id])
  bhcResult     BhcResult @relation(fields: [bhcResultId], references: [id])
  serviceRequests ServiceRequest[]

  @@index([userId])
  @@index([bhcResultId])
  @@map("bhc_gaps")
}

enum ServiceRequestStatus {
  PENDING_REVIEW
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Admin-managed directory of vetted service providers (CAC agents, bookkeepers,
// web designers, etc). No public self-serve onboarding yet — admin creates the
// account and profile together when bringing a provider onto the platform.
model Provider {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  businessName String   @map("business_name")
  serviceTags  String[] @map("service_tags")
  contactEmail String   @map("contact_email")
  contactPhone String   @map("contact_phone")
  active       Boolean  @default(true)
  avgRating    Float    @default(0) @map("avg_rating")
  reviewCount  Int      @default(0) @map("review_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id])
  serviceRequests ServiceRequest[]

  @@map("providers")
}

// A request to fix a specific BhcGap. Matching is admin-mediated for now —
// the SME requests, admin assigns a provider, provider tracks progress.
// Rating fields live here rather than a separate table to keep v1 simple.
model ServiceRequest {
  id            String               @id @default(cuid())
  gapId         String               @map("gap_id")
  userId        String               @map("user_id") // the SME who requested
  providerId    String?              @map("provider_id")
  status        ServiceRequestStatus @default(PENDING_REVIEW)
  priceAgreed   String?              @map("price_agreed") // informational only — payment happens outside the app
  adminNotes    String?              @map("admin_notes")
  providerNotes String?              @map("provider_notes")
  starRating    Int?                 @map("star_rating")
  reviewText    String?              @map("review_text")
  requestedAt   DateTime             @default(now()) @map("requested_at")
  assignedAt    DateTime?            @map("assigned_at")
  completedAt   DateTime?            @map("completed_at")
  ratedAt       DateTime?            @map("rated_at")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  gap      BhcGap    @relation(fields: [gapId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  provider Provider? @relation(fields: [providerId], references: [id])

  @@index([userId])
  @@index([providerId])
  @@index([gapId])
  @@map("service_requests")
}

model WibgApplication {
  id             String   @id @default(cuid())
  founderName    String   @map("founder_name")
  founderEmail   String   @map("founder_email")
  founderPhone   String   @map("founder_phone")
  businessName   String   @map("business_name")
  cacStatus      String   @map("cac_status")
  cacNumber      String?  @map("cac_number")
  problem        String
  solution       String
  market         String
  traction       String
  revenue3m      Float    @map("revenue_3m")
  proj12m        Float    @map("proj_12m")
  bhcRef         String   @map("bhc_ref")
  bizStage       String   @map("biz_stage")
  pitchVideoLink String?  @map("pitch_video_link")
  status         String   @default("SUBMITTED")
  videoTagged    Boolean  @default(false) @map("video_tagged")
  adminNotes     String?  @map("admin_notes")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  scores WibgScore[]

  @@map("wibg_applications")
}

// One row per (application, judge) — each logged-in admin scores independently
// against the published rubric; the panel average is computed on read, not stored.
model WibgScore {
  id               String   @id @default(cuid())
  applicationId    String   @map("application_id")
  judgeId          String   @map("judge_id")
  innovation       Int      @map("innovation")        // 0–25
  marketViability  Int      @map("market_viability")  // 0–20
  teamExecution    Int      @map("team_execution")    // 0–20
  financialClarity Int      @map("financial_clarity") // 0–20
  pitchDelivery    Int      @map("pitch_delivery")     // 0–15
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  application WibgApplication @relation(fields: [applicationId], references: [id])
  judge       User            @relation(fields: [judgeId], references: [id])

  @@unique([applicationId, judgeId])
  @@index([applicationId])
  @@map("wibg_scores")
}

model WibgAttendee {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String
  role      String
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("wibg_attendees")
}
